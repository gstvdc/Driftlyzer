{
  "name": "driftlyzer",
  "version": "0.1.0",
  "private": true,
  "description": "Driftlyzer: continuous repository consistency analyzer with structural parsing and targeted semantic review.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "scan": "npm run dev -w @drift/cli -- scan",
    "api:dev": "npm run dev -w @drift/api -- serve",
    "worker:run": "npm run dev -w @drift/worker -- run-pending",
    "dashboard:dev": "npm run dev -w @drift/dashboard",
    "dashboard:build": "npm run build -w @drift/dashboard",
    "prisma:generate": "npm run prisma:generate -w @drift/integrations",
    "prisma:migrate:dev": "npm run prisma:migrate:dev -w @drift/integrations --",
    "prisma:migrate:init": "npm run prisma:migrate:dev -- --name init",
    "prisma:db:push": "npm run prisma:db:push -w @drift/integrations",
    "test": "vitest run",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
