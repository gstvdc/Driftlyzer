# Persistence mode: filesystem (default) or postgres
DRIFTLYZER_PERSISTENCE=filesystem

# Required when DRIFTLYZER_PERSISTENCE=postgres
# Example for local postgres:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/driftlyzer?schema=public
DATABASE_URL=

# Queue mode: polling (default) or bullmq
DRIFTLYZER_QUEUE_MODE=polling

# Required when DRIFTLYZER_QUEUE_MODE=bullmq
REDIS_URL=
DRIFTLYZER_QUEUE_NAME=driftlyzer-scan-jobs

# Enable PR comment publishing in worker commands
DRIFTLYZER_PUBLISH_PR_COMMENT=false

# Option A: personal access token (PAT)
DRIFTLYZER_GITHUB_TOKEN=

# Option B: GitHub App auth
DRIFTLYZER_GITHUB_APP_ID=
DRIFTLYZER_GITHUB_APP_PRIVATE_KEY=

# Optional (GitHub Enterprise)
DRIFTLYZER_GITHUB_API_BASE_URL=https://api.github.com
